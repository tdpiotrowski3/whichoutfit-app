# Copy to .env.local and fill in. Full explanations in SETUP.md.

# --- Admin dashboard (required) ---
SUPABASE_URL=https://irfzsyzhoxxtzuugdtef.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_PASSWORD=
SESSION_SECRET=
CRON_SECRET=

# --- Marketing email via Resend (optional; bulk-send is inert until all set) ---
RESEND_API_KEY=
EMAIL_FROM=
MARKETING_PHYSICAL_ADDRESS=
PUBLIC_BASE_URL=

# --- Ops alerts (optional) ---
ADMIN_ALERT_EMAIL=

# --- Social & ads metrics (optional; each sync inert until set) ---
TIKTOK_ACCESS_TOKEN=
TIKTOK_BUSINESS_ID=
TIKTOK_ADVERTISER_ID=
META_ACCESS_TOKEN=
IG_USER_ID=
META_AD_ACCOUNT_ID=

# --- Google Play Console MCP server (.mcp.json; optional, dev tooling only) ---
# Path to the Google Cloud service-account JSON key (keep it out of git; the
# default lives under .secrets/). Only needed to use the "google-play" MCP server.
GOOGLE_PLAY_KEY_FILE=.secrets/google-play-service-account.json
GOOGLE_PLAY_PACKAGE_NAME=

# --- Consumer webapp (currently hidden while the focus is iOS) ---
# Set to true (and redeploy) to un-hide app.whichoutfit.app. See lib/flags.ts.
CONSUMER_WEBAPP_ENABLED=
NEXT_PUBLIC_SUPABASE_URL=https://irfzsyzhoxxtzuugdtef.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
